# Kafka and simulator
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENT_RATE=5
EVENT_RATE_JITTER=0.25
EVENT_SEED=42

# PostgreSQL warehouse
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_DB=airflow
WAREHOUSE_DB=warehouse
WAREHOUSE_SCHEMA=raw
WAREHOUSE_HOST=localhost
WAREHOUSE_PORT=5432

# Airflow (generate a new key for shared environments)
AIRFLOW_FERNET_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
AIRFLOW_SECRET_KEY=local-only-change-me
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Optional Databricks job integration used by Airflow
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=ecommerce
DATABRICKS_HTTP_PATH=
DATABRICKS_BRONZE_JOB_ID=
DATABRICKS_SILVER_JOB_ID=
DATABRICKS_QUALITY_JOB_ID=
DATABRICKS_WAREHOUSE_JOB_ID=
DBT_TARGET=dev

# Metabase bootstrap
METABASE_URL=http://localhost:3000
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=metabase123!
METABASE_ADMIN_FIRST_NAME=Data
